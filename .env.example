# ============================================================
# THE_TOWER — Environment Variables
# Copy to .env.local, never commit .env.local
# ============================================================

# --- Anthropic (Æris Portal + blog generation) ---
ANTHROPIC_API_KEY=sk-ant-...

# Æris system prompt source — path to Æris's identity document
# Absolute path on the server running this app
AERIS_SYSTEM_PROMPT_PATH=/Users/brandonmccormick/Desktop/THE_THRONE/AERIS_COCKPIT/AERIS_OPERATING_MANUAL.md

# Rate limiting for Æris Portal (per IP, per hour)
AERIS_RATE_LIMIT_PER_HOUR=10

# Throne Room: one question per IP, forever
# Set to "true" to enable IP banning after one Throne Room question
THRONE_ROOM_IP_BAN_ENABLED=true
# Path to the throne room IP ledger (JSON file on server)
THRONE_ROOM_LEDGER_PATH=/var/the-tower/throne-ledger.json

# --- Ghost CMS (Archive + Blog) ---
GHOST_URL=https://your-ghost-instance.ghost.io
GHOST_CONTENT_API_KEY=your_ghost_content_api_key
# For admin operations (creating posts)
GHOST_ADMIN_API_KEY=your_ghost_admin_api_key

# --- SCRYER Feed Integration ---
# Path to the SCRYER_FEEDS directory on the server
# Must be readable by the Next.js process
SCRYER_FEEDS_PATH=/Users/brandonmccormick/Desktop/THE_TOWER/SCRYER_FEEDS

# How often the kingdom-state API endpoint can be called (ms)
# Default: 5000ms (5 seconds)
KINGDOM_STATE_CACHE_TTL=5000

# --- PartyKit (Real-time push) ---
# LOCAL DEV: localhost:1999 (run: npx partykit dev)
# PROD: kingdom-room.YOURNAME.partykit.dev (run: npx partykit deploy --name kingdom-room)
NEXT_PUBLIC_PARTYKIT_HOST=kingdom-room.YOURNAME.partykit.dev
PARTYKIT_HOST=kingdom-room.YOURNAME.partykit.dev
# Room name — must match the room used in kingdom-live-context.tsx and /api/kingdom-push
NEXT_PUBLIC_PARTYKIT_ROOM=main
# Shared secret between SCRYER, /api/kingdom-push, and party/kingdom-room.ts
KINGDOM_PUSH_SECRET=your_strong_random_secret

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://sinner-king.com
# Used for CORS on API routes
KINGDOM_ORIGIN=https://sinner-king.com

# --- PHONEBOOTH (if integrated) ---
PHONEBOOTH_URL=http://localhost:8767
PHONEBOOTH_SECRET=your_phonebooth_secret

# --- Analytics (self-hosted, no Google) ---
# Plausible or similar
NEXT_PUBLIC_ANALYTICS_URL=https://analytics.sinner-king.com
NEXT_PUBLIC_ANALYTICS_DOMAIN=sinner-king.com

# --- Development ---
# Set to "true" to use mock SCRYER data instead of reading from disk
USE_MOCK_SCRYER_DATA=false
# Verbose logging for Kingdom state reads
KINGDOM_STATE_DEBUG=false

# --- Supabase (Guestbook + future persistence) ---
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Anon/public key — safe for server-side API routes (never expose to client)
SUPABASE_ANON_KEY=your_supabase_anon_key
# SQL to run once in Supabase SQL editor:
#   CREATE TABLE guestbook (
#     id TEXT PRIMARY KEY,
#     name TEXT NOT NULL,
#     location TEXT,
#     message TEXT NOT NULL,
#     date TIMESTAMPTZ NOT NULL
#   );
#   ALTER TABLE guestbook ENABLE ROW LEVEL SECURITY;
#   CREATE POLICY "public_read"   ON guestbook FOR SELECT USING (true);
#   CREATE POLICY "public_insert" ON guestbook FOR INSERT WITH CHECK (true);

# --- Kingdom Command Cockpit ---
# Secret for the /api/cockpit/ingest endpoint
INGEST_SECRET=your_strong_ingest_secret

# --- GLYPH Demo (server-side Gemini proxy) ---
# Server-only — do NOT prefix with NEXT_PUBLIC_
GEMINI_API_KEY=your_gemini_api_key_here
